{
  "name": "desktop-design-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "style": "./src/design-language.css",
  "exports": {
    "./css": "./src/design-language.css",
    "./css/docs": "./src/design-language.docs.css",
    "./css/*": "./css/*",
    "./icons/*": "./icons/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run icons:check && npm run reference:check && npm run reference:lint && npm run coverage:check && vite build && npm run bundle",
    "preview": "vite preview",
    "icons:build": "node tools/build-icons.mjs",
    "icons:check": "node tools/build-icons.mjs --check",
    "bundle": "node tools/bundle.mjs",
    "reference:build": "node tools/build-reference.mjs",
    "reference:check": "node tools/build-reference.mjs --check",
    "reference:lint": "node tools/lint-usage.mjs \"index.html\" \"pages/*.html\"",
    "coverage:check": "node tools/coverage.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook"
  },
  "devDependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/sora": "^5.2.8",
    "@iconify-json/lucide": "^1.2.66",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/test-runner": "^0.24.4",
    "@storybook/vue3-vite": "^10.4.6",
    "@types/node": "^26.0.0",
    "@types/sortablejs": "^1.15.8",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/test-utils": "^2.4.6",
    "axe-playwright": "^2.2.2",
    "esbuild": "^0.28.1",
    "happy-dom": "^16.7.0",
    "node-html-parser": "^8.0.3",
    "sortablejs": "^1.15.6",
    "storybook": "^10.4.6",
    "typescript": "^5.7.3",
    "vite": "^8.0.16",
    "vitest": "^3.0.5",
    "vue": "^3.5.13",
    "vue-component-meta": "^2.2.12",
    "vue-tsc": "^2.2.0"
  }
}
